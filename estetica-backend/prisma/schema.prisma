generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---

enum DocumentType {
  DNI
  PASSPORT
  OTHER
}

enum Role {
  ADMIN
  RECEPTIONIST
  PROFESSIONAL
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ExceptionType {
  HOLIDAY
  SICK_LEAVE
  PERSONAL
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
  DEBIT_CARD
}

enum PaymentType {
  DEPOSIT
  FINAL_PAYMENT
  FULL_PAYMENT
}

enum SyncStatus {
  SYNCHRONIZED
  PENDING
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  CANCEL
  RESCHEDULE
}

enum Channel {
  WHATSAPP
  EMAIL
  SMS
}

enum LogStatus {
  SENT
  FAILED
  READ
}

// --- MODELS ---

model People {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  documentType DocumentType @map("document_type")
  document     String
  cuilCuit     String       @default("") @map("cuil_cuit")
  email        String
  phone        String
  createdAt    DateTime     @default(now()) @map("created_at")

  user         User?
  professional Professional?
  patient      Patient?

  // El email deja de ser único: una persona puede gestionar turnos de
  // familiares con el mismo mail, y un typo no debe bloquear. El único
  // identificador inmutable es `id`. El duplicado de paciente por
  // (tipo + número de documento) se valida a nivel aplicación al crear,
  // dejando todos los campos editables ante un error de carga.
  @@map("people")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  peopleId        String    @unique @map("people_id") @db.Uuid
  passwordHash    String    @map("password_hash")
  role            Role
  active          Boolean   @default(true)
  lastLoginAt     DateTime? @map("last_login_at")

  person          People    @relation(fields: [peopleId], references: [id], onDelete: Cascade)
  createdAppointments Appointment[] @relation("CreatedBy")
  audits          AppointmentAudit[]

  @@map("users")
}

model Professional {
  id               String    @id @default(uuid()) @db.Uuid
  peopleId         String    @unique @map("people_id") @db.Uuid
  specialty        String
  bio              String?
  googleCalendarId String?   @map("google_calendar_id")
  active           Boolean   @default(true)

  person           People    @relation(fields: [peopleId], references: [id], onDelete: Cascade)
  services         ProfessionalService[]
  schedules        RecurringSchedule[]
  availabilities   Availability[]
  exceptions       AvailabilityException[]

  @@map("professionals")
}

model Patient {
  id           String   @id @default(uuid()) @db.Uuid
  peopleId     String   @unique @map("people_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  clinicalNotes String?      @map("clinical_notes")

  person       People   @relation(fields: [peopleId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("patients")
}

model ServiceCategory {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  displayOrder Int      @map("display_order")

  services     Service[]

  @@map("service_categories")
}

model Service {
  id                     String    @id @default(uuid()) @db.Uuid
  categoryId             String    @map("category_id") @db.Uuid
  name                   String
  defaultDurationMinutes Int       @map("default_duration_minutes")
  active                 Boolean   @default(true)

  requiresPreConsult     Boolean             @default(false) @map("requires_pre_consult")
  reminderNote           String?             @map("reminder_note")

  category               ServiceCategory @relation(fields: [categoryId], references: [id])
  professionalServices   ProfessionalService[]

  @@map("services")
}

model ProfessionalService {
  id              String   @id @default(uuid()) @db.Uuid
  professionalId  String   @map("professional_id") @db.Uuid
  serviceId       String   @map("service_id") @db.Uuid
  durationMinutes Int      @map("duration_minutes")
  price           Decimal  @db.Decimal(10, 2)
  // Agregamos el campo aquí:
  active          Boolean  @default(true)
  updatedAt       DateTime @updatedAt @map("updated_at")

  professional    Professional @relation(fields: [professionalId], references: [id])
  service         Service      @relation(fields: [serviceId], references: [id])
  appointments    Appointment[]

  @@map("professional_services")
}

model RecurringSchedule {
  id             String   @id @default(uuid()) @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  dayOfWeek      Int      @map("day_of_week")
  startTime      DateTime @db.Time @map("start_time")
  endTime        DateTime @db.Time @map("end_time")
  active         Boolean  @default(true)

  professional   Professional @relation(fields: [professionalId], references: [id])

  @@map("recurring_schedule")
}

model Availability {
  id             String   @id @default(uuid()) @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  date           DateTime @db.Date
  startTime      DateTime @db.Time @map("start_time")
  endTime        DateTime @db.Time @map("end_time")
  active         Boolean  @default(true)

  professional   Professional @relation(fields: [professionalId], references: [id])
  appointments   Appointment[]

  @@map("availability")
}

model AvailabilityException {
  id             String        @id @default(uuid()) @db.Uuid
  professionalId String        @map("professional_id") @db.Uuid
  exceptionDate  DateTime      @db.Date @map("exception_date")
  startTime      DateTime      @db.Time @map("start_time")
  endTime        DateTime      @db.Time @map("end_time")
  exceptionType  ExceptionType @map("exception_type")
  reason         String?

  professional   Professional  @relation(fields: [professionalId], references: [id])

  @@map("availability_exception")
}

model Appointment {
  id                    String            @id @default(uuid()) @db.Uuid
  professionalServiceId String            @map("professional_service_id") @db.Uuid
  availabilityId        String?           @map("availability_id") @db.Uuid
  patientId             String            @map("patient_id") @db.Uuid
  createdByUserId       String            @map("created_by_user_id") @db.Uuid
  startsAt              DateTime          @map("starts_at")
  endsAt                DateTime          @map("ends_at")
  status                AppointmentStatus @default(PENDING)
  priceSnapshot         Decimal           @db.Decimal(10, 2) @map("price_snapshot")
  discountAmount        Decimal?          @db.Decimal(10, 2) @map("discount_amount")
  discountReason        String?           @map("discount_reason")
  depositAmount         Decimal?          @db.Decimal(10, 2) @map("deposit_amount")
  paymentStatus         PaymentStatus     @default(PENDING) @map("payment_status")
  notes                 String?
  isOverbook            Boolean           @default(false) @map("is_overbook")
  rescheduleRequestedAt DateTime?         @map("reschedule_requested_at")
  googleEventId         String?           @map("google_event_id")
  googleSyncStatus      SyncStatus        @default(PENDING) @map("google_sync_status")
  createdAt             DateTime          @default(now()) @map("created_at")

  professionalService   ProfessionalService @relation(fields: [professionalServiceId], references: [id])
  availability          Availability?       @relation(fields: [availabilityId], references: [id])
  patient               Patient             @relation(fields: [patientId], references: [id])
  creator               User                @relation("CreatedBy", fields: [createdByUserId], references: [id])
  audits                AppointmentAudit[]
  payments              Payment[]
  reminders             ReminderLog[]

  @@map("appointments")
}

model AppointmentAudit {
  id            String            @id @default(uuid()) @db.Uuid
  appointmentId String            @map("appointment_id") @db.Uuid
  action        AuditAction
  prevStatus    AppointmentStatus? @map("prev_status")
  newStatus     AppointmentStatus @map("new_status")
  performedBy   String            @map("performed_by") @db.Uuid
  performedAt   DateTime          @default(now()) @map("performed_at")

  appointment   Appointment       @relation(fields: [appointmentId], references: [id])
  user          User              @relation(fields: [performedBy], references: [id])

  @@map("appointment_audit")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  appointmentId String        @map("appointment_id") @db.Uuid
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @map("payment_method")
  type          PaymentType   @map("payment_type")
  paidAt        DateTime      @default(now()) @map("paid_at")
  isRefund      Boolean       @default(false) @map("is_refund")

  appointment   Appointment   @relation(fields: [appointmentId], references: [id])

  @@map("payments")
}

model ReminderLog {
  id            String    @id @default(uuid()) @db.Uuid
  appointmentId String    @map("appointment_id") @db.Uuid
  sentAt        DateTime  @default(now()) @map("sent_at")
  channel       Channel
  status        LogStatus

  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  @@map("reminder_log")
}